                    </div>
                </details>

                <details class="capex-accordion">
                    <summary class="capex-accordion__summary">
                        <span class="capex-accordion__title">Транспортные средства</span>
                        <span class="capex-accordion__meta">Ключ: CAPEX_амортизация</span>
                    </summary>
                    <div class="capex-accordion__content">
                        <div class="capex-accordion__chips">
                            <span class="capex-chip">Наименование объекта</span>
                            <span class="capex-chip">Первоначальная стоимость</span>
                            <span class="capex-chip">НДС</span>
                            <span class="capex-chip">Транспортный налог</span>
                            <span class="capex-chip">Мощность, л.с.</span>
                            <span class="capex-chip">Срок полезного использования</span>
                        </div>
                        <button class="capex-accordion__add-btn" type="button">+ Подуровень</button>
                    </div>
                </details>

                <details class="capex-accordion">
                    <summary class="capex-accordion__summary">
                        <span class="capex-accordion__title">Нематериальные активы и ПО</span>
                        <span class="capex-accordion__meta">Ключ: CAPEX_амортизация</span>
                    </summary>
                    <div class="capex-accordion__content">
                        <div class="capex-accordion__chips">
                            <span class="capex-chip">Наименование объекта</span>
                            <span class="capex-chip">Первоначальная стоимость</span>
                            <span class="capex-chip">НДС</span>
                            <span class="capex-chip">Срок полезного использования</span>
                        </div>
                        <button class="capex-accordion__add-btn" type="button">+ Подуровень</button>
                    </div>
                </details>

                <details class="capex-accordion">
                    <summary class="capex-accordion__summary">
                        <span class="capex-accordion__title">Неотделимые улучшения арендованного имущества</span>
                        <span class="capex-accordion__meta">Ключ: CAPEX_амортизация</span>
                    </summary>
                    <div class="capex-accordion__content">
                        <div class="capex-accordion__chips">
                            <span class="capex-chip">Ремонт арендованных средств</span>
                            <span class="capex-chip">НДС</span>
                            <span class="capex-chip">Срок договора аренды</span>
                            <span class="capex-chip">Налог на имущество</span>
                        </div>
                        <button class="capex-accordion__add-btn" type="button">+ Подуровень</button>
                    </div>
                </details>

                <details class="capex-accordion">
                    <summary class="capex-accordion__summary">
                        <span class="capex-accordion__title">Другое</span>
                        <span class="capex-accordion__meta">Ключ: CAPEX_амортизация, если включена амортизация</span>
                    </summary>
                    <div class="capex-accordion__content">
                        <div class="capex-accordion__chips">
                            <span class="capex-chip">Первоначальная стоимость</span>
                            <span class="capex-chip">НДС</span>
                            <span class="capex-chip">Амортизируется / не амортизируется</span>
                            <span class="capex-chip">Срок полезного использования</span>
                        </div>
                        <button class="capex-accordion__add-btn" type="button">+ Подуровень</button>
                    </div>
                </details>
            </div>
        </div>
    </div>
</section>
