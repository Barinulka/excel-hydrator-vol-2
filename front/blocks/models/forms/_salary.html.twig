<form class="model-form" action="{{ path('front', {slug: 'placeholder'}) }}" method="post">
    <article class="model-panel">
        <h3 class="model-panel__title">Зарплаты</h3>
        <div class="model-salary-list">
            <div class="model-salary-list__row">
                <span>Finance Analyst</span>
                <strong>190 000 ₽</strong>
            </div>
            <div class="model-salary-list__row">
                <span>Data Engineer</span>
                <strong>240 000 ₽</strong>
            </div>
            <div class="model-salary-list__row">
                <span>Product Manager</span>
                <strong>260 000 ₽</strong>
            </div>
        </div>

        <div class="model-fields model-fields--three">
            <label class="model-field">
                <span class="model-field__label">Индексация в год, %</span>
                <input class="project-form__input" type="number" value="6.0" step="0.1">
            </label>
            <label class="model-field">
                <span class="model-field__label">Бонусный пул, %</span>
                <input class="project-form__input" type="number" value="12.0" step="0.1">
            </label>
            <label class="model-field">
                <span class="model-field__label">Налоги на ФОТ, %</span>
                <input class="project-form__input" type="number" value="30.2" step="0.1">
            </label>
        </div>
    </article>

    <div class="project-form__actions">
        <button class="project-form__submit" type="submit">Сохранить вкладку</button>
    </div>
</form>
