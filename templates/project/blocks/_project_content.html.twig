{% set selectedProject = page.selectedProject|default(null) %}

{% if selectedProject %}
    <article class="project-summary-card">
        <h3 class="project-summary-card__title">{{ selectedProject.title|default('Без названия') }}</h3>
        <p class="project-summary-card__meta">Код проекта: {{ selectedProject.code|default('NO CODE') }}</p>
        <p class="project-summary-card__text">
            {{ selectedProject.description ?: 'Описание проекта пока не заполнено.' }}
        </p>
    </article>

    <div class="projects-empty" data-controller="project-model-create-dialog">
        <h3 class="projects-empty__title">{{ selectedProject.hasModels ? 'Добавить модель' : 'Создать модель' }}</h3>
        <p class="projects-empty__text">
            {{ selectedProject.hasModels ? 'В проекте уже есть модели. Можно создать еще одну версию.' : 'У выбранного проекта пока нет добавленных моделей.' }}
        </p>
        <button
            class="projects-empty__btn"
            type="button"
            data-action="project-model-create-dialog#open"
            {% if not modelCreateApiUrl %}disabled{% endif %}
        >
            Создать модель
        </button>

        {#  попап создания модели  #}
        {{ include('project/blocks/_model_create_modal.html.twig') }}
    </div>

    {% if selectedProject.hasModels and selectedProject.modelStubs|default([]) %}
        {% for model in selectedProject.modelStubs %}
            {% set renameToggleId = 'model_rename_toggle_' ~ loop.index ~ '_' ~ model.shortId %}
            {% set renameInputId = 'model_rename_input_' ~ loop.index ~ '_' ~ model.shortId %}
            <article
                class="model-card"
                data-controller="model-rename"
                data-model-rename-api-url-value="{{ (selectedProject.shortId and model.shortId) ? path('api_model_title_update', { projectShortId: selectedProject.shortId, modelShortId: model.shortId }) : '' }}"
            >
                <input
                    class="model-card__rename-toggle-input"
                    data-model-rename-target="toggle"
                    data-action="change->model-rename#toggleChanged"
                    type="checkbox"
                    id="{{ renameToggleId }}"
                >

                <div class="model-card__header">
                    <h3 class="model-card__title" data-model-rename-target="title">{{ model.title }}</h3>
                    <label
                        class="model-card__rename-toggle"
                        for="{{ renameToggleId }}"
                        aria-label="Изменить название модели"
                        title="Изменить название"
                    >
                        ✎
                    </label>
                </div>

                <form
                    class="model-card__rename-form"
                    action="{{ (selectedProject.shortId and model.shortId) ? path('api_model_title_update', { projectShortId: selectedProject.shortId, modelShortId: model.shortId }) : '#' }}"
                    method="post"
                    data-turbo-frame="project_content"
                    data-action="submit->model-rename#submit"
                >
                    <input
                        id="{{ renameInputId }}"
                        class="project-form__input model-card__rename-input"
                        data-model-rename-target="input"
                        type="text"
                        name="title"
                        value="{{ model.title }}"
                        maxlength="255"
                        required
                    >
                    <div class="model-card__rename-actions">
                        <button
                            class="projects-content__action model-card__rename-submit"
                            data-model-rename-target="submit"
                            type="submit"
                        >
                            Сохранить
                        </button>
                        <label class="model-card__rename-cancel" for="{{ renameToggleId }}">Отмена</label>
                    </div>
                </form>

                <p class="model-card__text">{{ model.description }}</p>
                <a
                    class="model-card__link"
                    href="{{ (selectedProject.shortId and model.shortId) ? path('app_model_time_params', { projectShortId: selectedProject.shortId, modelShortId: model.shortId }) : '#' }}"
                    data-turbo-frame="_top"
                    {% if not (selectedProject.shortId and model.shortId) %}aria-disabled="true"{% endif %}
                >
                    К модели
                </a>
            </article>
        {% endfor %}
    {% endif %}
{% else %}
    <div class="projects-empty">
        <h3 class="projects-empty__title">Проектов пока нет</h3>
        <p class="projects-empty__text">Добавьте проект, чтобы здесь появилась информация по выбранному проекту.</p>
        <a class="projects-empty__btn" href="{{ path('app_project_create') }}" data-turbo-frame="project_content">Добавить проект</a>
    </div>
{% endif %}
